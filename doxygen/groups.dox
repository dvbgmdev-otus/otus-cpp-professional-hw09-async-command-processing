/** @file groups.dox
 *  @brief Группы документации проекта
 */

/** @defgroup main_group Демонстрационная утилита
 *  @brief Точка входа исполняемого файла bulk.
 */

/** @defgroup async_group Библиотека async
 *  @brief Публичный интерфейс асинхронной обработки команд.
 */

/** @defgroup async_internal_group Внутренняя реализация async
 *  @brief Контексты, runtime, очереди и рабочие потоки библиотеки async.
 */

/** @defgroup cli_group Аргументы командной строки
 *  @brief Разбор и валидация параметров запуска.
 */

/** @defgroup model_group Модель данных
 *  @brief Общие структуры данных, передаваемые между компонентами.
 */

/** @defgroup processor_group Пакетирование команд
 *  @brief Бизнес-логика формирования статических и динамических блоков.
 */

/** @defgroup format_group Форматирование блоков
 *  @brief Преобразование готовых блоков команд в текстовое представление.
 */

/** @defgroup output_group Вывод блоков
 *  @brief Запись готовых блоков в консоль и log-файлы.
 */

/** @defgroup input_group Чтение команд
 *  @brief Вспомогательное построчное чтение команд из входного потока.
 */
